---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    id: 'tourism-dashboard',
    title: 'Tourism Operations Dashboard',
    industry: 'Hotels, tours, villas, and local operators',
    service: 'Business Intelligence Dashboard',
    number: '01',
    problem: 'Bookings, revenue, channel performance, and daily operations often live across separate tools. Owners can lose time reconciling exports instead of seeing what needs attention today.',
    solution: 'Connect booking, payment, spreadsheet, and CRM data into a dashboard that shows occupancy, revenue, lead source quality, and operational follow-ups in one place.',
    outcomes: [
      { value: 'Live view', label: 'Current bookings and revenue' },
      { value: 'Less admin', label: 'Fewer manual reporting steps' },
      { value: 'Better focus', label: 'Clear daily priorities' },
    ],
    bestFit: 'Businesses that already collect data but do not have one reliable operating view.',
    timeline: '2-5 weeks',
  },
  {
    id: 'whatsapp-automation',
    title: 'WhatsApp Enquiry Automation',
    industry: 'Service businesses and appointment-led teams',
    service: 'AI Chatbot & Automation',
    number: '02',
    problem: 'Potential customers often ask the same questions before booking. If the reply is slow, unclear, or manual, good leads can go cold before a person responds.',
    solution: 'Build a WhatsApp-friendly enquiry flow that answers common questions, captures the customer need, qualifies the lead, and routes the conversation to the right person.',
    outcomes: [
      { value: '24/7', label: 'Basic enquiry coverage' },
      { value: 'Cleaner leads', label: 'Useful context before calls' },
      { value: 'Faster replies', label: 'Less repetitive admin' },
    ],
    bestFit: 'Teams that receive frequent enquiries through WhatsApp, web forms, or social channels.',
    timeline: '2-4 weeks',
  },
  {
    id: 'conversion-website',
    title: 'Conversion Website Rebuild',
    industry: 'Local services, B2B firms, and specialist offers',
    service: 'Website Redesign & CRO',
    number: '03',
    problem: 'Many business websites look acceptable but do not explain the offer clearly, load quickly on mobile, or guide visitors toward an enquiry.',
    solution: 'Redesign the site around clear positioning, fast performance, useful service pages, trust-building content, and visible contact paths.',
    outcomes: [
      { value: 'Clear offer', label: 'Visitors understand quickly' },
      { value: 'Fast pages', label: 'Mobile-first performance' },
      { value: 'Better tracking', label: 'Know which channels work' },
    ],
    bestFit: 'Businesses with a useful offer but a website that is not yet helping sales.',
    timeline: '4-8 weeks',
  },
];
---

<BaseLayout
  title="Projects | Adiban Digital"
  description="Example projects for AI automation, BI dashboards, internal tools, and conversion-focused websites."
>
  <Nav />

  <main class="pt-32 pb-32">

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-10 items-end" data-reveal>
        <div>
          <p class="text-[10px] font-medium text-brand-accent uppercase tracking-[0.2em] mb-3">Projects</p>
          <h1 class="font-heading font-bold text-4xl lg:text-5xl text-brand-heading leading-tight">
            Practical ways<br />we can help
          </h1>
        </div>
        <p class="text-brand-text text-lg leading-relaxed max-w-[55ch] lg:pb-1">
          These are example project directions, not published client results. Once real outcomes are approved for publication, this page can become a fuller previous work section.
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      {projects.map((project, i) => (
        <article id={project.id} data-reveal data-delay={String(Math.min(i, 2))}>
          <div class="p-[3px] rounded-squircle bg-black/[0.03] ring-1 ring-black/[0.07] hover:ring-black/[0.12] hover:shadow-soft-lg transition-all duration-[600ms] ease-spring">
            <div class="bg-white rounded-squircle-in shadow-inner-highlight overflow-hidden">

              <div class="p-8 border-b border-brand-border bg-brand-surface1">
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div>
                    <div class="flex items-center gap-3 mb-2">
                      <span class="font-mono text-[10px] text-brand-muted tracking-[0.12em]">{project.number}</span>
                      <span class="text-[10px] font-medium uppercase tracking-[0.15em] text-brand-accent">{project.service}</span>
                    </div>
                    <h2 class="font-heading font-bold text-2xl text-brand-heading">{project.title}</h2>
                    <p class="text-brand-muted text-sm mt-0.5">{project.industry}</p>
                  </div>
                  <div class="p-[2px] rounded-full bg-black/[0.04] ring-1 ring-black/[0.07]">
                    <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-white text-xs font-medium text-brand-text">
                      <svg class="w-3.5 h-3.5 text-brand-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"/>
                      </svg>
                      {project.timeline}
                    </div>
                  </div>
                </div>
              </div>

              <div class="p-8 grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-10">

                <div class="space-y-6">
                  <div>
                    <h3 class="text-[10px] font-medium text-brand-muted uppercase tracking-[0.18em] mb-3">The Problem</h3>
                    <p class="text-brand-text text-sm leading-relaxed">{project.problem}</p>
                  </div>
                  <div>
                    <h3 class="text-[10px] font-medium text-brand-muted uppercase tracking-[0.18em] mb-3">What We Build</h3>
                    <p class="text-brand-text text-sm leading-relaxed">{project.solution}</p>
                  </div>
                  <div class="border-l-2 border-brand-accent pl-5">
                    <h3 class="text-[10px] font-medium text-brand-muted uppercase tracking-[0.18em] mb-2">Best Fit</h3>
                    <p class="text-brand-text text-sm leading-relaxed">{project.bestFit}</p>
                  </div>
                </div>

                <div class="space-y-3">
                  <h3 class="text-[10px] font-medium text-brand-muted uppercase tracking-[0.18em] mb-4">Expected Outcomes</h3>
                  {project.outcomes.map(({ value, label }) => (
                    <div class="p-[3px] rounded-squircle bg-black/[0.025] ring-1 ring-black/[0.06]">
                      <div class="bg-brand-surface1 rounded-squircle-in shadow-inner-highlight p-4 text-center">
                        <p class="font-heading font-bold text-xl text-brand-accent">{value}</p>
                        <p class="text-xs text-brand-muted mt-1 leading-snug">{label}</p>
                      </div>
                    </div>
                  ))}
                  <a
                    href="/contact"
                    class="group mt-4 flex items-center justify-between pl-4 pr-1.5 py-1.5 rounded-full bg-brand-heading text-white text-sm font-medium hover:bg-brand-accent transition-all duration-[600ms] ease-spring shadow-soft-sm hover:shadow-accent-glow active:scale-[0.99]"
                  >
                    Discuss this project
                    <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center transition-all duration-300 ease-spring group-hover:bg-white/20 group-hover:translate-x-0.5">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                      </svg>
                    </span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-20" data-reveal>
      <div class="p-[3px] rounded-squircle bg-black/[0.04] ring-1 ring-black/[0.08]">
        <div class="rounded-squircle-in bg-brand-heading relative overflow-hidden">
          <div class="absolute inset-0 opacity-[0.055]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 48px 48px;" aria-hidden="true"></div>
          <div class="relative z-10 grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 items-center p-10">
            <div>
              <h2 class="font-heading font-bold text-2xl text-white mb-2">Have a different system in mind?</h2>
              <p class="text-white/60 text-sm leading-relaxed max-w-[52ch]">
                Send a short brief. We will tell you what is realistic, what to avoid, and the simplest first version to build.
              </p>
            </div>
            <a
              href="/contact"
              class="group inline-flex items-center justify-between pl-6 pr-1.5 py-2 rounded-full bg-white text-brand-heading font-medium text-sm hover:bg-brand-accent hover:text-white transition-all duration-[600ms] ease-spring shadow-soft-md active:scale-[0.99] flex-shrink-0"
            >
              Contact Adiban Digital
              <span class="ml-3 w-8 h-8 rounded-full bg-brand-heading/10 flex items-center justify-center transition-all duration-300 ease-spring group-hover:bg-white/20 group-hover:translate-x-0.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
