---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import { mapHref, siteConfig } from '../config/site';

const contactCards = [
  {
    label: 'Email',
    value: siteConfig.email,
    href: `mailto:${siteConfig.email}`,
    tone: 'brand',
    icon: 'email',
  },
  {
    label: 'WhatsApp',
    value: siteConfig.whatsappDisplay,
    href: siteConfig.whatsappHref,
    tone: 'emerald',
    icon: 'whatsapp',
  },
  {
    label: 'Office',
    value: siteConfig.location,
    href: mapHref,
    tone: 'brand',
    icon: 'pin',
  },
];
---

<BaseLayout
  title="Contact | Adiban Digital"
  description="Contact Adiban Digital in Phuket for AI automation, BI dashboards, internal tools, and conversion-focused websites."
>
  <Nav />

  <main class="pt-32 pb-32 px-4">
    <div class="max-w-7xl mx-auto">

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-10 items-end mb-16" data-reveal>
        <div>
          <p class="text-[10px] font-medium text-brand-accent uppercase tracking-[0.2em] mb-3">Get in touch</p>
          <h1 class="font-heading font-bold text-4xl lg:text-5xl text-brand-heading tracking-tight leading-tight">
            Let's talk<br />about your<br />business
          </h1>
        </div>
        <p class="text-brand-text text-lg leading-relaxed max-w-[52ch] lg:pb-1">
          Tell us what you want to build, automate, or improve. We will respond with a practical next step, not a generic sales pitch.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.4fr] gap-12" data-reveal data-delay="1">

        <div class="space-y-6">

          <div class="p-[2px] rounded-full bg-black/[0.04] ring-1 ring-black/[0.07] inline-block">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-white text-xs font-medium text-brand-text">
              <span class="relative flex h-1.5 w-1.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-400"></span>
              </span>
              Phuket-based, remote-ready
            </div>
          </div>

          <div class="space-y-3">
            {contactCards.map((card) => (
              <a
                href={card.href}
                class:list={[
                  'group block p-[3px] rounded-squircle bg-black/[0.03] ring-1 ring-black/[0.07] hover:shadow-soft-md transition-all duration-[600ms] ease-spring hover:-translate-y-0.5',
                  card.tone === 'emerald' ? 'hover:ring-emerald-200' : 'hover:ring-black/[0.12]',
                ]}
              >
                <div class="bg-white rounded-squircle-in shadow-inner-highlight flex items-center gap-4 p-4">
                  <div class:list={[
                    'w-10 h-10 rounded-[1.1rem] flex items-center justify-center flex-shrink-0 transition-colors duration-300',
                    card.tone === 'emerald' ? 'bg-emerald-50' : 'bg-brand-surface1 group-hover:bg-brand-accent-subtle',
                  ]}>
                    {card.icon === 'email' && (
                      <svg class="w-4 h-4 text-brand-muted group-hover:text-brand-accent transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                      </svg>
                    )}
                    {card.icon === 'whatsapp' && (
                      <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                      </svg>
                    )}
                    {card.icon === 'pin' && (
                      <svg class="w-4 h-4 text-brand-muted group-hover:text-brand-accent transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                      </svg>
                    )}
                  </div>
                  <div>
                    <p class="text-[10px] text-brand-muted mb-0.5 uppercase tracking-[0.12em]">{card.label}</p>
                    <p class="text-sm text-brand-heading font-medium group-hover:text-brand-accent transition-colors duration-300">{card.value}</p>
                  </div>
                </div>
              </a>
            ))}

            <div class="p-[3px] rounded-squircle bg-black/[0.02] ring-1 ring-black/[0.05]">
              <div class="bg-brand-surface1 rounded-squircle-in shadow-inner-highlight flex items-start gap-4 p-4">
                <div class="w-10 h-10 rounded-[1.1rem] bg-brand-surface2 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-brand-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] text-brand-muted mb-0.5 uppercase tracking-[0.12em]">Response time</p>
                  <p class="text-sm text-brand-heading font-medium">Within 1 business day</p>
                  <p class="text-xs text-brand-muted mt-1 leading-relaxed">For urgent website or automation issues, WhatsApp is the fastest route.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="p-[3px] rounded-squircle bg-black/[0.03] ring-1 ring-black/[0.07]">
            <div class="bg-white rounded-squircle-in shadow-inner-highlight p-6">
              <h3 class="font-heading font-semibold text-brand-heading text-sm mb-5">What happens next</h3>
              <ol class="space-y-4">
                {[
                  'We review your message and respond within one business day',
                  'We clarify the goal, timeline, budget, and systems involved',
                  'If there is a fit, we schedule a focused discovery call',
                  'You receive a clear scope, fixed price, and next steps',
                ].map((step, i) => (
                  <li class="flex items-start gap-3">
                    <span class="flex-shrink-0 w-5 h-5 rounded-full bg-brand-accent-subtle ring-1 ring-brand-accent/20 text-brand-accent text-[10px] font-semibold flex items-center justify-center mt-0.5">
                      {i + 1}
                    </span>
                    <span class="text-brand-text text-sm leading-relaxed">{step}</span>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </div>

        <div class="p-[3px] rounded-squircle bg-black/[0.03] ring-1 ring-black/[0.07]">
          <div class="bg-white rounded-squircle-in shadow-inner-highlight p-8 lg:p-10">
            <h2 class="font-heading font-semibold text-brand-heading text-lg tracking-tight mb-6">Send us a message</h2>
            <ContactForm />
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
