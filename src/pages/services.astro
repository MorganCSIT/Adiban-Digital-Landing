---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    number: '01',
    name: 'AI Chatbot & Automation',
    tag: 'Most requested',
    problem: 'You\'re missing leads after hours, and your team spends significant time answering the same questions repeatedly.',
    description: 'We design and deploy AI chatbots that qualify inbound leads, answer FAQs, and book appointments automatically — 24 hours a day, across your website and WhatsApp.',
    includes: [
      'Custom conversation flows mapped to your qualification criteria',
      'Integration with your calendar, CRM, and WhatsApp Business',
      'Lead scoring logic and segmentation',
      'Human escalation triggers with full context handoff',
      'Knowledge base built from your existing content',
      '30-day post-launch monitoring and tuning',
    ],
    timeline: '2–4 weeks',
  },
  {
    number: '02',
    name: 'Business Intelligence Dashboards',
    tag: '',
    problem: 'Your key metrics live across five different tools. Week-end reporting takes days and is always slightly out of date.',
    description: 'We connect your data sources — accounting, CRM, e-commerce, ops — and build live dashboards that surface the numbers leadership actually needs.',
    includes: [
      'Data source audit and connection mapping',
      'Custom dashboard design and build in Power BI or Metabase',
      'Role-based access (executive view vs. operational view)',
      'Automated alerts when key thresholds are breached',
      'Staff training and documentation',
      '60-day support and iteration period',
    ],
    timeline: '2–5 weeks',
  },
  {
    number: '03',
    name: 'Website Redesign & CRO',
    tag: '',
    problem: 'You\'re getting traffic but very few enquiries. The site looks reasonable but doesn\'t convert.',
    description: 'We redesign with conversion as the primary objective — clear value propositions, fast load times, strong social proof, and CTAs that work.',
    includes: [
      'Full CRO audit of your current site with annotated findings',
      'New sitemap and information architecture',
      'Custom design — no purchased templates',
      'Astro or Next.js development with Core Web Vitals optimisation',
      'On-page SEO: meta, schema markup, internal linking structure',
      'Google Analytics 4 and conversion event tracking',
    ],
    timeline: '4–8 weeks',
  },
  {
    number: '04',
    name: 'Internal Tools & Portals',
    tag: '',
    problem: 'Your team is managing complex workflows in spreadsheets or cobbled-together SaaS tools that weren\'t built for your process.',
    description: 'We build custom internal applications — admin panels, client portals, approval workflows, inventory systems — designed around how your business actually operates.',
    includes: [
      'Requirements workshop and workflow mapping session',
      'Custom UI design and full-stack development',
      'Role-based authentication and permission system',
      'Integration with existing systems via API',
      'Hosted infrastructure setup and monitoring',
      'Documentation and staff onboarding session',
    ],
    timeline: '4–10 weeks',
  },
  {
    number: '05',
    name: 'Systems & API Integration',
    tag: '',
    problem: 'Your CRM, accounting software, e-commerce platform, and marketing tools don\'t communicate — so data lives in silos and manual exports multiply.',
    description: 'We map your tool stack, identify the critical data flows, and build integrations that keep everything in sync automatically.',
    includes: [
      'Full tech stack audit and integration dependency mapping',
      'No-code automation via Zapier or Make for standard flows',
      'Custom API integrations for complex or unsupported requirements',
      'Data transformation, field mapping, and validation logic',
      'Error handling, logging, and alert system',
      'Full documentation of every integration flow',
    ],
    timeline: '1–4 weeks per integration',
  },
  {
    number: '06',
    name: 'Digital Strategy Consulting',
    tag: 'Good starting point',
    problem: 'You know you need to invest in digital, but you\'re not sure where to start — and you\'ve been burned by spending on things that didn\'t deliver.',
    description: 'We audit your current digital presence and operations, then deliver a prioritised roadmap with clear ROI projections for each initiative.',
    includes: [
      'Digital presence and website audit with annotated findings',
      'CRM and data maturity assessment',
      'Competitor digital benchmark across three to five comparators',
      'Identification of top three revenue-driving opportunities',
      'Prioritised 90-day roadmap with effort/impact scoring',
      'Presentation and working session with your leadership team',
    ],
    timeline: '1–2 weeks',
  },
];
---

<BaseLayout
  title="Services | Adiban Digital"
  description="AI automation, BI dashboards, internal tools, systems integration, and conversion-focused websites from Adiban Digital in Phuket."
>
  <Nav />

  <main class="pt-32 pb-32">
    <!-- Page header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-10 items-end" data-reveal>
        <div>
          <p class="text-[10px] font-medium text-brand-accent uppercase tracking-[0.2em] mb-3">Services</p>
          <h1 class="font-heading font-bold text-4xl lg:text-5xl text-brand-heading tracking-tight leading-tight">
            What we<br />build for you
          </h1>
        </div>
        <p class="text-brand-text text-lg leading-relaxed max-w-[55ch] lg:pb-1">
          Every engagement is scoped around a specific, measurable business problem. We build practical IT systems for Phuket, Thailand, and remote clients.
        </p>
      </div>
    </div>

    <!-- Service blocks — double-bezel -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-5">
      {services.map((service, i) => (
        <div data-reveal data-delay={String(Math.min(i, 3))}>
          <div class="p-[3px] rounded-squircle bg-black/[0.03] ring-1 ring-black/[0.07] hover:ring-black/[0.12] hover:shadow-soft-lg transition-all duration-[600ms] ease-spring">
            <div class="relative bg-white rounded-squircle-in shadow-inner-highlight p-8 lg:p-10">

              {service.tag && (
                <span class="absolute top-8 right-8 px-2.5 py-1 text-[10px] font-medium rounded-full bg-brand-accent-subtle text-brand-accent ring-1 ring-brand-accent/20 uppercase tracking-[0.12em]">
                  {service.tag}
                </span>
              )}

              <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-10">
                <!-- Left -->
                <div>
                  <div class="flex items-baseline gap-4 mb-6">
                    <span class="font-mono text-[10px] text-brand-muted tracking-[0.12em]">{service.number}</span>
                    <h2 class="font-heading font-bold text-2xl text-brand-heading tracking-tight">{service.name}</h2>
                  </div>

                  <!-- Problem quote -->
                  <div class="mb-5 p-[3px] rounded-[1.25rem] bg-black/[0.025] ring-1 ring-black/[0.06]">
                    <div class="bg-brand-surface1 rounded-[1rem] shadow-inner-highlight p-4">
                      <p class="text-[10px] text-brand-muted uppercase tracking-[0.15em] font-medium mb-2">The problem</p>
                      <p class="text-brand-text text-sm leading-relaxed">"{service.problem}"</p>
                    </div>
                  </div>

                  <p class="text-brand-text leading-relaxed mb-6 text-sm">{service.description}</p>

                  <div class="flex items-center gap-4 flex-wrap">
                    <a
                      href="/contact"
                      class="group inline-flex items-center justify-between pl-5 pr-1.5 py-2 rounded-full bg-brand-heading text-white font-medium text-sm hover:bg-brand-accent transition-all duration-[600ms] ease-spring shadow-soft-md hover:shadow-accent-glow active:scale-[0.99]"
                    >
                      Get a Quote
                      <span class="ml-2.5 w-7 h-7 rounded-full bg-white/15 flex items-center justify-center transition-all duration-300 ease-spring group-hover:bg-white/20 group-hover:translate-x-0.5">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                      </span>
                    </a>
                    <span class="text-xs text-brand-muted">
                      <span class="font-medium text-brand-text">Timeline:</span> {service.timeline}
                    </span>
                  </div>
                </div>

                <!-- Right: What's included -->
                <div>
                  <h3 class="text-[10px] font-medium text-brand-muted uppercase tracking-[0.18em] mb-5">What's included</h3>
                  <ul class="space-y-3">
                    {service.includes.map((item) => (
                      <li class="flex items-start gap-3">
                        <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                        </svg>
                        <span class="text-brand-text text-sm leading-relaxed">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA — double-bezel -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-20" data-reveal>
      <div class="p-[3px] rounded-squircle bg-black/[0.03] ring-1 ring-black/[0.07]">
        <div class="bg-white rounded-squircle-in shadow-inner-highlight p-10 grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 items-center">
          <div>
            <h2 class="font-heading font-bold text-2xl text-brand-heading tracking-tight mb-2">
              Not sure which service fits?
            </h2>
            <p class="text-brand-text text-sm leading-relaxed max-w-[55ch]">
              Book a free 30-minute discovery call. We'll listen to your situation and recommend the highest-leverage starting point — even if that means pointing you elsewhere.
            </p>
          </div>
          <a
            href="/contact"
            class="group inline-flex items-center justify-between pl-6 pr-1.5 py-2 rounded-full bg-brand-heading text-white font-medium text-sm hover:bg-brand-accent transition-all duration-[600ms] ease-spring shadow-soft-md hover:shadow-accent-glow active:scale-[0.99] flex-shrink-0"
          >
            Book a Free Discovery Call
            <span class="ml-3 w-8 h-8 rounded-full bg-white/15 flex items-center justify-center transition-all duration-300 ease-spring group-hover:bg-white/20 group-hover:translate-x-0.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
