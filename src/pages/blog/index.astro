---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog | Adiban Digital"
  description="Practical guides on business intelligence, AI automation, websites, and digital strategy for growing businesses."
>
  <Nav />

  <main class="pt-32 pb-32 px-4">
    <div class="max-w-7xl mx-auto">

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-10 items-end mb-14" data-reveal>
        <div>
          <p class="text-[10px] font-medium text-brand-accent uppercase tracking-[0.2em] mb-3">The Blog</p>
          <h1 class="font-heading font-bold text-4xl lg:text-5xl text-brand-heading tracking-tight leading-tight">
            Insights<br />worth reading
          </h1>
        </div>
        <p class="text-brand-text text-lg leading-relaxed max-w-[55ch] lg:pb-1">
          Practical guides on BI, AI automation, and web strategy. Written for business owners and operators — not developers.
        </p>
      </div>

      <div data-reveal data-delay="1">
      {sorted.length > 0 ? (
        sorted.length === 1 ? (
          <div class="max-w-xl">
            <BlogCard
              title={sorted[0].data.title}
              description={sorted[0].data.description}
              pubDate={sorted[0].data.pubDate}
              category={sorted[0].data.category}
              readTime={sorted[0].data.readTime}
              slug={sorted[0].slug}
              featured={true}
            />
          </div>
        ) : (
          <div class="grid grid-cols-1 lg:grid-cols-[1.6fr_1fr] gap-5">
            <!-- Featured first post -->
            <BlogCard
              title={sorted[0].data.title}
              description={sorted[0].data.description}
              pubDate={sorted[0].data.pubDate}
              category={sorted[0].data.category}
              readTime={sorted[0].data.readTime}
              slug={sorted[0].slug}
              featured={true}
            />
            <!-- Remaining posts stacked -->
            <div class="flex flex-col gap-5">
              {sorted.slice(1).map((post) => (
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  readTime={post.data.readTime}
                  slug={post.slug}
                  featured={false}
                />
              ))}
            </div>
          </div>
        )
      ) : (
        <div class="py-24 text-center p-[3px] rounded-squircle bg-black/[0.03] ring-1 ring-black/[0.07]">
          <div class="bg-white rounded-squircle-in shadow-inner-highlight py-24">
            <p class="text-brand-muted text-sm">No posts yet — check back soon.</p>
          </div>
        </div>
      )}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
