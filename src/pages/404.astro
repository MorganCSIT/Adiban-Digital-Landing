---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page Not Found | Adiban Digital"
  description="The page you are looking for could not be found."
>
  <Nav />

  <main class="min-h-[70vh] pt-32 pb-24 px-4 flex items-center">
    <section class="max-w-3xl mx-auto text-center" data-reveal>
      <p class="text-[10px] font-medium text-brand-accent uppercase tracking-[0.2em] mb-4">404</p>
      <h1 class="font-heading font-bold text-4xl lg:text-5xl text-brand-heading leading-tight mb-5">
        This page is not here.
      </h1>
      <p class="text-brand-text text-lg leading-relaxed max-w-[48ch] mx-auto mb-8">
        The link may be old, moved, or mistyped. Head back home or contact us if you were looking for a specific service.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="group inline-flex items-center justify-between pl-5 pr-1.5 py-2 rounded-full bg-brand-heading text-white font-medium text-sm hover:bg-brand-accent transition-all duration-[600ms] ease-spring shadow-soft-md active:scale-[0.99]"
        >
          Back Home
          <span class="ml-3 w-7 h-7 rounded-full bg-white/15 flex items-center justify-center transition-all duration-300 ease-spring group-hover:bg-white/20 group-hover:translate-x-0.5">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white text-brand-heading font-medium text-sm ring-1 ring-black/[0.08] shadow-soft-xs hover:shadow-soft-md hover:ring-black/[0.14] transition-all duration-500 ease-spring active:scale-[0.97]"
        >
          Contact Us
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
