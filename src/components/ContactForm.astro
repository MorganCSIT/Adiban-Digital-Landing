---
import { siteConfig } from '../config/site';

const formAction = `https://formsubmit.co/${siteConfig.email}`;
const successUrl = `${siteConfig.url}/contact?sent=1`;
---

<div id="form-wrap">
  <div id="form-success" class="hidden flex-col items-center justify-center py-20 text-center">
    <div class="p-[3px] rounded-squircle bg-emerald-100/50 ring-1 ring-emerald-200/70 mb-5 inline-block">
      <div class="w-14 h-14 rounded-squircle-in bg-emerald-50 flex items-center justify-center">
        <svg class="w-7 h-7 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
        </svg>
      </div>
    </div>
    <h3 class="font-heading font-semibold text-xl text-brand-heading tracking-tight mb-2">Message sent</h3>
    <p class="text-brand-muted text-sm">Thanks. We will reply within one business day.</p>
  </div>

  <form
    id="contact-form"
    action={formAction}
    method="POST"
    accept-charset="UTF-8"
    class="space-y-4"
  >
    <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hidden" />
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_subject" value="New Adiban Digital enquiry" />
    <input id="form-next" type="hidden" name="_next" value={successUrl} />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1.5">
        <label for="firstName" class="block text-xs font-medium text-brand-heading uppercase tracking-wider">First Name <span class="text-brand-accent">*</span></label>
        <input id="firstName" type="text" name="firstName" required placeholder="Morgan"
          class="w-full px-4 py-3 rounded-xl bg-brand-bg ring-1 ring-black/[0.08] text-brand-heading placeholder-brand-muted text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/30 transition-all duration-300"
        />
      </div>
      <div class="space-y-1.5">
        <label for="lastName" class="block text-xs font-medium text-brand-heading uppercase tracking-wider">Last Name <span class="text-brand-accent">*</span></label>
        <input id="lastName" type="text" name="lastName" required placeholder="Smith"
          class="w-full px-4 py-3 rounded-xl bg-brand-bg ring-1 ring-black/[0.08] text-brand-heading placeholder-brand-muted text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/30 transition-all duration-300"
        />
      </div>
    </div>

    <div class="space-y-1.5">
      <label for="email" class="block text-xs font-medium text-brand-heading uppercase tracking-wider">Work Email <span class="text-brand-accent">*</span></label>
      <input id="email" type="email" name="email" required placeholder="you@company.com"
        class="w-full px-4 py-3 rounded-xl bg-brand-bg ring-1 ring-black/[0.08] text-brand-heading placeholder-brand-muted text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/30 transition-all duration-300"
      />
    </div>

    <div class="space-y-1.5">
      <label for="company" class="block text-xs font-medium text-brand-heading uppercase tracking-wider">Company</label>
      <input id="company" type="text" name="company" placeholder="Your company"
        class="w-full px-4 py-3 rounded-xl bg-brand-bg ring-1 ring-black/[0.08] text-brand-heading placeholder-brand-muted text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/30 transition-all duration-300"
      />
    </div>

    <div class="space-y-1.5">
      <label for="service" class="block text-xs font-medium text-brand-heading uppercase tracking-wider">Service <span class="text-brand-accent">*</span></label>
      <div class="relative">
        <select id="service" name="service" required
          class="w-full px-4 py-3 rounded-xl bg-brand-bg ring-1 ring-black/[0.08] text-brand-heading text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/30 transition-all duration-300 appearance-none pr-10"
        >
          <option value="" disabled selected>Select a service...</option>
          <option value="ai-chatbot">AI Chatbot &amp; Automation</option>
          <option value="bi-dashboards">Business Intelligence Dashboards</option>
          <option value="website-cro">Website Redesign &amp; CRO</option>
          <option value="internal-tools">Internal Tools &amp; Portals</option>
          <option value="systems-integration">Systems &amp; API Integration</option>
          <option value="digital-strategy">Digital Strategy Consulting</option>
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-3.5 flex items-center">
          <svg class="w-4 h-4 text-brand-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="space-y-1.5">
      <label for="budget" class="block text-xs font-medium text-brand-heading uppercase tracking-wider">Budget Range <span class="text-brand-accent">*</span></label>
      <div class="relative">
        <select id="budget" name="budget" required
          class="w-full px-4 py-3 rounded-xl bg-brand-bg ring-1 ring-black/[0.08] text-brand-heading text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/30 transition-all duration-300 appearance-none pr-10"
        >
          <option value="" disabled selected>Select a budget...</option>
          <option value="under-70k-thb">Under THB 70,000</option>
          <option value="70k-175k-thb">THB 70,000 - 175,000</option>
          <option value="175k-500k-thb">THB 175,000 - 500,000</option>
          <option value="500k-plus-thb">THB 500,000+</option>
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-3.5 flex items-center">
          <svg class="w-4 h-4 text-brand-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="space-y-1.5">
      <label for="description" class="block text-xs font-medium text-brand-heading uppercase tracking-wider">Project brief <span class="text-brand-accent">*</span></label>
      <textarea id="description" name="description" required rows="4"
        placeholder="Briefly describe what you want to build, automate, or improve..."
        class="w-full px-4 py-3 rounded-xl bg-brand-bg ring-1 ring-black/[0.08] text-brand-heading placeholder-brand-muted text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/30 transition-all duration-300 resize-none"
      ></textarea>
    </div>

    <button
      type="submit"
      class="group w-full flex items-center justify-between pl-6 pr-1.5 py-2 rounded-full bg-brand-heading text-white font-medium text-sm hover:bg-brand-accent transition-all duration-600 ease-spring shadow-soft-md hover:shadow-accent-glow active:scale-[0.99]"
    >
      Send Message
      <span class="w-8 h-8 rounded-full bg-white/15 flex items-center justify-center transition-all duration-300 ease-spring group-hover:bg-white/20 group-hover:translate-x-0.5">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </span>
    </button>

    <p class="text-center text-xs text-brand-muted">
      The form sends to {siteConfig.email}. You can also email or WhatsApp us directly.
    </p>
  </form>
</div>

<script>
  const form = document.getElementById('contact-form');
  const success = document.getElementById('form-success');
  const next = document.getElementById('form-next') as HTMLInputElement | null;
  const params = new URLSearchParams(window.location.search);

  if (next) {
    next.value = `${window.location.origin}/contact?sent=1`;
  }

  if (params.get('sent') === '1' && form && success) {
    form.classList.add('hidden');
    success.classList.remove('hidden');
    success.classList.add('flex');
    window.history.replaceState({}, document.title, window.location.pathname);
  }
</script>
