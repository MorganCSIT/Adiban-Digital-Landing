---
import { mapHref, siteConfig } from '../config/site';

const year = new Date().getFullYear();
const cols = [
  { heading: 'Services', links: [
    { href: '/services', label: 'AI Chatbot & Automation' },
    { href: '/services', label: 'BI Dashboards' },
    { href: '/services', label: 'Website Redesign & CRO' },
    { href: '/services', label: 'Internal Tools' },
    { href: '/services', label: 'Systems Integration' },
    { href: '/services', label: 'Digital Strategy' },
  ]},
  { heading: 'Company', links: [
    { href: '/blog', label: 'Blog' },
    { href: '/projects', label: 'Projects' },
    { href: '/contact', label: 'Contact' },
  ]},
  { heading: 'Connect', links: [
    { href: `mailto:${siteConfig.email}`, label: siteConfig.email },
    { href: siteConfig.whatsappHref, label: siteConfig.whatsappDisplay },
    { href: mapHref, label: siteConfig.location },
  ]},
];
---

<footer class="border-t border-brand-border bg-brand-surface1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.6fr_1fr_1fr_1fr] gap-10 mb-14">

      <div>
        <a href="/" class="inline-flex items-center gap-2 mb-5 group">
          <div class="p-[2px] rounded-full bg-black/[0.05] ring-1 ring-black/[0.07]">
            <div class="w-7 h-7 rounded-full bg-brand-heading flex items-center justify-center transition-all duration-500 ease-spring group-hover:bg-brand-accent">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M6 1L11 10H1L6 1Z" fill="white"/>
              </svg>
            </div>
          </div>
          <span class="font-heading font-semibold text-brand-heading text-sm tracking-tight">
            Adiban<span class="text-brand-accent">.Digital</span>
          </span>
        </a>
        <p class="text-brand-muted text-sm leading-relaxed max-w-[30ch] mb-5">
          {siteConfig.tagline}
        </p>
        <address class="not-italic text-xs text-brand-muted leading-relaxed mb-5">
          {siteConfig.address.map((line) => (
            <span class="block">{line}</span>
          ))}
        </address>
        <div class="inline-flex items-center gap-2">
          <span class="relative flex h-1.5 w-1.5">
            <span class="animate-pulse-dot absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-400"></span>
          </span>
          <span class="text-xs text-brand-muted">Available for new projects</span>
        </div>
      </div>

      {cols.map(({ heading, links }) => (
        <div>
          <h4 class="text-[10px] font-medium text-brand-muted uppercase tracking-[0.18em] mb-5">{heading}</h4>
          <ul class="space-y-3">
            {links.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm text-brand-muted hover:text-brand-heading transition-colors duration-300">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-brand-border">
      <p class="text-xs text-brand-muted">&copy; {year} Adiban Digital. All rights reserved.</p>
      <div class="flex items-center gap-5">
        <a href="/sitemap.xml" class="text-xs text-brand-muted hover:text-brand-heading transition-colors duration-300">Sitemap</a>
        <span class="text-xs text-brand-muted">Built with Astro</span>
      </div>
    </div>
  </div>
</footer>
