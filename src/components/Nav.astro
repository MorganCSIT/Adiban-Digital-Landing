---
const navLinks = [
  { href: '/services',     label: 'Services' },
  { href: '/blog',         label: 'Blog' },
  { href: '/projects',     label: 'Projects' },
  { href: '/contact',      label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<!-- Soft-skill: Floating glass pill — NOT edge-to-edge sticky bar -->
<header class="fixed top-0 left-0 right-0 z-50 flex justify-center px-4 pt-5">
  <nav
    id="navbar-pill"
    class="w-full max-w-2xl flex items-center justify-between gap-4 px-3 py-2 rounded-full bg-white/[0.97] ring-1 ring-black/[0.07] shadow-soft-md transition-shadow duration-700 ease-spring"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 pl-1 group flex-shrink-0">
      <div class="w-7 h-7 rounded-full bg-brand-heading flex items-center justify-center transition-all duration-600 ease-spring group-hover:bg-brand-accent">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M6 1L11 10H1L6 1Z" fill="white"/>
        </svg>
      </div>
      <span class="font-heading font-semibold text-brand-heading text-sm tracking-tight">
        Adiban<span class="text-brand-accent">.Digital</span>
      </span>
    </a>

    <!-- Desktop links — centered -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm transition-colors duration-300',
            currentPath.startsWith(href)
              ? 'text-brand-heading font-medium'
              : 'text-brand-muted hover:text-brand-heading font-normal',
          ]}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- CTA — pill button-in-button pattern -->
    <div class="flex items-center gap-2">
      <a
        href="/contact"
        class="hidden md:inline-flex items-center gap-1 pl-4 pr-1.5 py-1.5 rounded-full bg-brand-heading text-white text-sm font-medium hover:bg-brand-accent transition-all duration-600 ease-spring active:scale-[0.97] group"
      >
        Book a Call
        <!-- Button-in-Button trailing icon (soft-skill Section 4B) -->
        <span class="w-6 h-6 rounded-full bg-white/15 flex items-center justify-center ml-1 transition-all duration-300 ease-spring group-hover:bg-white/20 group-hover:translate-x-0.5 group-hover:-translate-y-[1px]">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>

      <!-- Mobile hamburger — morphs into X -->
      <button
        id="menu-btn"
        aria-label="Toggle menu"
        class="md:hidden w-8 h-8 rounded-full flex flex-col items-center justify-center gap-1.5 hover:bg-black/5 transition-all duration-300"
      >
        <span id="line-1" class="block w-4 h-[1.5px] bg-brand-heading rounded-full transition-all duration-500 ease-spring origin-center"></span>
        <span id="line-2" class="block w-4 h-[1.5px] bg-brand-heading rounded-full transition-all duration-500 ease-spring origin-center"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile overlay — screen-filling glass modal with stagger reveal -->
<div
  id="mobile-overlay"
  class="fixed inset-0 z-40 flex flex-col justify-center px-6 bg-white/92 backdrop-blur-2xl pointer-events-none opacity-0 transition-all duration-600 ease-spring"
  aria-hidden="true"
>
  <nav class="space-y-1">
    {navLinks.map(({ href, label }, i) => (
      <a
        href={href}
        class="mobile-nav-link block py-4 font-heading font-semibold text-3xl text-brand-heading border-b border-brand-border/60 translate-y-8 opacity-0 transition-all duration-700 ease-spring"
        style={`transition-delay: ${100 + i * 60}ms`}
      >
        {label}
      </a>
    ))}
    <div class="pt-6 mobile-nav-link translate-y-8 opacity-0 transition-all duration-700 ease-spring" style="transition-delay: 340ms">
      <a
        href="/contact"
        class="inline-flex items-center gap-1 pl-5 pr-1.5 py-2 rounded-full bg-brand-heading text-white font-medium hover:bg-brand-accent transition-all duration-500 ease-spring group"
      >
        Book a Call
        <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center ml-1 transition-all duration-300 group-hover:translate-x-0.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
    </div>
  </nav>
</div>

<script>
  const btn     = document.getElementById('menu-btn')!;
  const overlay = document.getElementById('mobile-overlay')!;
  const line1   = document.getElementById('line-1')!;
  const line2   = document.getElementById('line-2')!;
  const links   = document.querySelectorAll('.mobile-nav-link');
  let open = false;

  btn.addEventListener('click', () => {
    open = !open;
    if (open) {
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      overlay.setAttribute('aria-hidden', 'false');
      // Hamburger → X morph
      line1.style.transform = 'translateY(5px) rotate(45deg)';
      line2.style.transform = 'translateY(-5px) rotate(-45deg)';
      // Stagger reveal nav items
      links.forEach(el => {
        el.classList.remove('translate-y-8', 'opacity-0');
        el.classList.add('translate-y-0', 'opacity-100');
      });
    } else {
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100');
      overlay.setAttribute('aria-hidden', 'true');
      line1.style.transform = '';
      line2.style.transform = '';
      links.forEach(el => {
        el.classList.add('translate-y-8', 'opacity-0');
        el.classList.remove('translate-y-0', 'opacity-100');
      });
    }
  });

  // Close on nav link click
  links.forEach(el => el.addEventListener('click', () => btn.click()));
</script>
